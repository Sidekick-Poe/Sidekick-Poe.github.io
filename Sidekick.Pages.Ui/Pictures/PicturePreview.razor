<div class="flex flex-col gap-2 @Class">
    <div class="relative group cursor-pointer overflow-hidden rounded-lg border border-stone-700"
         onclick="window.open('@Image', '_blank')">
        <img src="@Image" alt="@Title" class="w-full h-auto object-cover transition-transform duration-300 group-hover:scale-105 @ImageClass"/>
        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <Icon Svg="@UiIcons.Expand" Class="text-white" Size="UiIconSize.Large"/>
        </div>
    </div>
    @if (!string.IsNullOrEmpty(Title))
    {
        <TextCaption Class="text-center">@Title</TextCaption>
    }
</div>

@code {
    [Parameter]
    public string? Image { get; set; }

    [Parameter]
    public string? Title { get; set; }

    [Parameter]
    public string ImageClass { get; set; } = "aspect-[968/768]";

    [Parameter]
    public string? Class { get; set; }
}
