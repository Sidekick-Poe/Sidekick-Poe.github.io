<a href="@Href"
   target="@Target"
   class="inline-flex items-center justify-center px-6 py-4 text-base font-medium tracking-wide text-white transition-colors duration-200 rounded-md bg-violet-700 hover:bg-violet-500 @UiClasses.FocusClasses">
    @ChildContent
</a>

@code {

    [Parameter] public required RenderFragment ChildContent { get; set; }

    [Parameter] public required string Href { get; set; }

    [Parameter] public string Target { get; set; } = "_self";

}
