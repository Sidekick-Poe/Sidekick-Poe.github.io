<a href="@Href"
   target="@Target"
   class="inline-flex items-center justify-center px-4 py-2 text-base font-medium tracking-wide dark:text-violet-500 transition-colors duration-200 rounded-md bg-transparent hover:text-violet-400 @UiClasses.FocusClasses">
    @ChildContent
</a>

@code {

    [Parameter] public required RenderFragment ChildContent { get; set; }

    [Parameter] public required string Href { get; set; }

    [Parameter] public string Target { get; set; } = "_self";

}
