<div class="flex flex-col gap-6" id="about">
    <Heading1 Class="text-center">About</Heading1>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <Card Title="Major Contributors">
            <ul class="flex flex-col gap-2">
                @foreach (var (name, link) in MajorContributors)
                {
                    <li>
                        <a href="@link" target="_blank"
                           class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                    </li>
                }
            </ul>
        </Card>

        <Card Title="Recent Contributors">
            <ul class="flex flex-col gap-2">
                @foreach (var (name, link) in RecentContributors)
                {
                    <li>
                        <a href="@link" target="_blank"
                           class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                    </li>
                }
            </ul>
        </Card>

        <Card Title="Translators">
            <ul class="flex flex-col gap-2">
                @foreach (var (name, link) in Translators)
                {
                    <li>
                        <a href="@link" target="_blank"
                           class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                    </li>
                }
            </ul>
        </Card>

        <Card Title="Other Contributors">
            <ul class="grid grid-cols-2 gap-2">
                @foreach (var (name, link) in OtherContributors)
                {
                    <li>
                        <a href="@link" target="_blank"
                           class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                    </li>
                }
            </ul>
        </Card>

        <div class="md:col-span-2">
            <Card Title="Path of Exile Community">
                <div class="flex flex-col gap-4">
                    <TextBase>
                        Sidekick is made possible due to the amazing Path of Exile community. Here are some shoutouts.
                    </TextBase>
                    <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
                        @foreach (var (name, link) in PathOfExileCommunity)
                        {
                            <li>
                                <a href="@link" target="_blank"
                                   class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                            </li>
                        }
                    </ul>
                </div>
            </Card>

        </div>

        <div class="md:col-span-2">
            <Card Title="Third Parties">
                <ul class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-2">
                    @foreach (var (name, link) in ThirdParties)
                    {
                        <li>
                            <a href="@link" target="_blank"
                               class="text-violet-700 dark:text-violet-400 hover:underline">@name</a>
                        </li>
                    }
                </ul>
            </Card>
        </div>
    </div>
</div>

