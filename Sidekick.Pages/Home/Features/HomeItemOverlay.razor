<Card>
    <TitleContent>
        <div class="flex flex-wrap items-center gap-4">
            <Heading2>Item Overlay</Heading2>
            <Chip>Default Binding: Ctrl+D</Chip>
        </div>
    </TitleContent>
    <ChildContent>
        <div class="flex flex-col gap-4">
            <TextBase>
                Hover any item in Path of Exile and press <b>Ctrl+D</b> to open the item overlay. Get instant pricing for currency items,
                smarter trade searches and quick map safety checks - without leaving the game.
            </TextBase>

            <CardDivider/>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <PicturePreview Image="/pages/item_divine.png" Title="Currency exchange information"/>
                <PicturePreview Image="/pages/item_uniquevaluation.png" Title="Unique item valuation"/>
            </div>
            <TextBase>
                See up-to-date currency values via poe.ninja and poe2scout.com, right inside Sidekick.
            </TextBase>

            <CardDivider/>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <PicturePreview Image="/pages/item_rareresults.png" Title="Rare item filters and results"/>
                <PicturePreview Image="/pages/item_uniqueresults.png" Title="Unique item filters and results"/>
            </div>
            <TextBase>
                Build and tweak trade filters in seconds, then view results from the official trade site directly in Sidekick.
            </TextBase>

            <CardDivider/>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <PicturePreview Image="/pages/item_mapbad.png" Title="Bad map modifiers"/>
                <PicturePreview Image="/pages/item_mapgood.png" Title="Good map"/>
            </div>
            <TextBase>
                Paste a map/area regex from poe.re to quickly flag dangerous or invalid mods.
            </TextBase>
        </div>
    </ChildContent>
</Card>
